# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-long-random-secret-string

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=jewelry_store

# Session
SESSION_TYPE=filesystem
SESSION_PERMANENT=False
PERMANENT_SESSION_LIFETIME=86400

# CORS
# Only used when the frontend is served by a SEPARATE static server.
# If you run `python app.py` and open http://localhost:5000, this is irrelevant
# (same-origin). Set it to the URL that serves your static files.
CORS_ORIGIN=http://localhost:8000

# Uploads
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=8388608

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
